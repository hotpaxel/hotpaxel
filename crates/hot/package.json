{
    "name": "@hotpaxel/hot",
    "version": "0.2.0-alpha.6",
    "description": "High-Performance HTML ↔ TeX Converter",
    "keywords": [
        "latex",
        "tex",
        "html",
        "converter",
        "wasm",
        "rust"
    ],
    "license": "MIT",
    "author": "Minchul Kwon <mstorm@mstorm.net>",
    "private": false,
    "publishConfig": {
        "access": "public",
        "provenance": false
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/hotpaxel/hotpaxel"
    },
    "main": "pkg/hot.js",
    "module": "pkg/hot.js",
    "types": "pkg/hot.d.ts",
    "scripts": {
        "build": "wasm-pack build --target web --scope hotpaxel",
        "test": "cargo test",
        "lint": "cargo fmt --all -- --check && cargo clippy --all-targets --all-features -- -D warnings",
        "clean": "rm -rf pkg .turbo"
    },
    "devDependencies": {
        "wasm-pack": "^0.14.0"
    }
}