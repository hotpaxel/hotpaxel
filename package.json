{
  "name": "hotpaxel",
  "private": true,
  "packageManager": "bun@1.1.0",
  "workspaces": [
    "crates/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "cargo clean && find . -type d \\( -name \"target\" -o -name \"target_local\" -o -name \"pkg\" -o -name \"dist\" -o -name \".turbo\" \\) -exec rm -rf {} +",
    "purge": "bun run clean && find . -name \"node_modules\" -type d -exec rm -rf {} +"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  }
}